    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #030303;
            --card-bg: rgba(255, 255, 255, 0.02);
            --text: #ffffff;
            --subtext: #888888;
            --border: rgba(255, 255, 255, 0.06);
            --accent-yellow: #fff9c4;
            --glass-white: rgba(255, 255, 255, 0.05);
            --liquid-glow: rgba(255, 255, 255, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            overflow-x: hidden;
            line-height: 1.5;
        }

        /* Particle Canvas Background */
        #canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            opacity: 0.4;
        }

        /* Navigation */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 25px 10%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(3, 3, 3, 0.5);
            backdrop-filter: blur(20px);
            z-index: 1000;
            border-bottom: 1px solid var(--border);
        }

        .logo {
            font-weight: 800;
            letter-spacing: 3px;
            font-size: 1.1rem;
            text-transform: uppercase;
        }

        .nav-linkz {
            display: flex;
            gap: 40px;
        }

        .nav-linkz a {
            text-decoration: none;
            color: var(--subtext);
            font-size: 0.85rem;
            font-weight: 600;
            transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .nav-linkz a:hover {
            color: var(--text);
            transform: translateY(-2px);
        }

        /* Hero Section */
        .hero {
            height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 0 20px;
            position: relative;
        }

        .pfp-container {
            position: relative;
            margin-bottom: 40px;
            perspective: 1000px;
        }

        .pfp-main {
            width: 160px;
            height: 160px;
            border-radius: 50px;
            border: 1px solid var(--border);
            box-shadow: 0 30px 60px rgba(0,0,0,0.8);
            animation: float 6s ease-in-out infinite;
            transition: transform 0.5s ease;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0) scale(1); }
            50% { transform: translateY(-20px) scale(1.05); }
        }

        h1 {
            font-size: clamp(3rem, 10vw, 5.5rem);
            font-weight: 800;
            letter-spacing: -4px;
            margin-bottom: 15px;
            background: linear-gradient(180deg, #fff 0%, #444 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero p {
            color: var(--subtext);
            font-size: 1.4rem;
            max-width: 600px;
            margin-bottom: 40px;
        }

        /* Liquid Glass Buttonz */
        .btn-wrap {
            display: flex;
            gap: 20px;
        }

        .liquid-btn {
            position: relative;
            padding: 18px 40px;
            border-radius: 18px;
            text-decoration: none;
            color: #fff;
            font-weight: 600;
            background: var(--glass-white);
            border: 1px solid var(--border);
            backdrop-filter: blur(15px);
            overflow: hidden;
            transition: 0.4s all ease;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        .liquid-btn::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            opacity: 0;
            transition: 0.5s;
        }

        .liquid-btn:hover {
            transform: translateY(-8px) scale(1.02);
            border-color: rgba(255,255,255,0.2);
            box-shadow: 0 20px 40px rgba(255,255,255,0.05);
            background: var(--liquid-glow);
        }

        .liquid-btn:hover::after {
            opacity: 1;
        }

        /* Feature Section */
        .section {
            padding: 120px 10%;
        }

        .section-title {
            font-size: 2.5rem;
            margin-bottom: 60px;
            text-align: center;
            letter-spacing: -1px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 30px;
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            padding: 50px;
            border-radius: 32px;
            transition: 0.7s cubic-bezier(0.15, 0.85, 0.35, 1);
            transform-style: preserve-3d;
            cursor: pointer;
        }

        .card:hover {
            transform: translateY(-15px) rotateX(8deg) rotateY(-8deg);
            background: rgba(255, 255, 255, 0.04);
            border-color: rgba(255, 255, 255, 0.15);
        }

        .card-icon {
            width: 50px;
            height: 50px;
            stroke: #fff;
            stroke-width: 1.5;
            fill: none;
            margin-bottom: 25px;
            transition: 0.5s;
        }

        .card:hover .card-icon {
            transform: translateZ(30px);
        }

        .card h3 {
            font-size: 1.5rem;
            margin-bottom: 15px;
        }

        .card p {
            color: var(--subtext);
            font-size: 1rem;
        }

        /* Command Table Section */
        .cmd-section {
            background: #060606;
            padding: 100px 10%;
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
        }

        .cmd-row {
            display: flex;
            justify-content: space-between;
            padding: 25px 0;
            border-bottom: 1px solid var(--border);
            transition: 0.3s;
        }

        .cmd-row:hover {
            padding-left: 20px;
            background: rgba(255,255,255,0.01);
        }

        .cmd-name { font-weight: 800; color: #fff; }
        .cmd-desc { color: var(--subtext); }

        /* FAQ Section */
        .faq-section {
            padding: 100px 10%;
            background: var(--bg);
        }

        /* Termz Footer */
        .footer-cta {
            padding: 150px 10%;
            text-align: center;
        }

        .termz-box {
            background: var(--accent-yellow);
            color: #000;
            padding: 70px;
