            display: inline-block;
            width: 100%;
            max-width: 800px;
            text-decoration: none;
            transition: 0.5s cubic-bezier(0.2, 1, 0.3, 1);
            box-shadow: 0 40px 100px rgba(0,0,0,0.5);
        }

        .termz-box:hover {
